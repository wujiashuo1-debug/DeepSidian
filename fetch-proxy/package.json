{
  "name": "fetch-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend proxy that fetches a URL and returns clean extracted text.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
